// Prisma schema: the single source of truth for the LiveStore + TanStack DB
// todo model. Two generators consume it:
//
//   1. `effect_client` — the published `prisma-effect-schema-generator`
//      npm package. Emits `@livestore/utils/effect` `Schema.*` values
//      plus the introspection maps the integration factory consumes
//      (`PRIMARY_KEY_COLUMNS`, `SOFT_DELETE_COLUMNS`, `TABLES`).
//
//   2. `client` — the standard Prisma Client, useful for ad-hoc D1 reads.
//
// `provider = "sqlite"` is what Prisma uses for local type checking +
// migration generation. The actual D1 database is provisioned by
// Alchemy (`alchemy.run.ts`) and Prisma's migration SQL is diff'd into
// `prisma/migrations/` then pointed at via `Cloudflare.D1.Database`'s
// `migrationsDir`.
datasource db {
  provider = "sqlite"
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

generator effect_client {
  provider          = "prisma-effect-schema-generator"
  output            = "./generated/client-schemas/index.ts"
  effectImport      = "@livestore/utils/effect"
  // Introspection maps the integration factory consumes:
  idColumn          = "true"
  softDeleteColumn  = "true"
  tables            = "true"
  exportModelNames  = "true"
  exportModelNameType = "true"
  // Wrap every schema in Schema.standardSchemaV1 so it satisfies
  // State.SQLite.clientDocument's Schema<T, _, never> slot without an
  // `as never` cast. Also makes the schemas usable as Standard Schema
  // v1 (TanStack DB accepts them directly).
  standardSchemaV1  = "true"
}

model Todo {
  id        String    @id
  text      String
  completed Boolean   @default(false)
  deletedAt DateTime? @map("deleted_at")

  @@map("todos")
}

// LiveStore's `events` log. This is the durable, queryable mirror that
// the LiveStore sync-cf Durable Object writes to on every `onPush`. It
// is *not* the source of truth — LiveStore's own SQLite event log is —
// but it lets you replay history into other systems, run analytics, or
// rebuild a region from a backup.
model Event {
  id        Int      @id @default(autoincrement())
  storeId   String   @map("store_id")
  name      String
  args      String
  createdAt DateTime @default(now()) @map("created_at")

  @@index([storeId, id])
  @@map("events")
}