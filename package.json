{
  "name": "livestore-tanstack-db-workspace",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "typecheck": "bun run --filter '*' typecheck",
    "build": "bun run --filter '*' build",
    "dev:spa": "cd examples/spa && bun run dev",
    "dev:start-orpc": "cd examples/tanstack-start-orpc && bun run dev",
    "deploy:spa": "cd examples/spa && bun alchemy deploy",
    "deploy:start-orpc": "cd examples/tanstack-start-orpc && bun alchemy deploy"
  }
}
