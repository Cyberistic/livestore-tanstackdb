{
  "name": "livestore-tanstack-db",
  "version": "0.1.0",
  "description": "LiveStore + TanStack DB integration. Pattern B adapter, useTable hook, lazy db proxy, oRPC write-back, and React provider. Independent of Prisma — works with any source of LiveStore schemas.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./devtools": {
      "types": "./dist/devtools/index.d.ts",
      "import": "./dist/devtools/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@standard-schema/spec": "^1.1.0",
    "@tanstack/devtools-event-client": "^0.5.0",
    "@tanstack/react-db": "^0.1.0",
    "livestore-prisma": "workspace:*"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.0.0",
    "@tanstack/devtools": "^0.12.0",
    "@tanstack/react-devtools": "^0.10.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "effect": "^4.0.0-beta",
    "typescript": "^5.4.0"
  },
  "peerDependencies": {
    "@livestore/livestore": "npm:@livestore/livestore@snapshot",
    "@tanstack/db": "^0.6.0",
    "effect": "^3.0.0 || ^4.0.0",
    "react": "^19.0.0"
  },
  "peerDependenciesMeta": {
    "@livestore/livestore": {
      "optional": false
    },
    "@tanstack/db": {
      "optional": false
    },
    "effect": {
      "optional": false
    },
    "react": {
      "optional": false
    }
  }
}
