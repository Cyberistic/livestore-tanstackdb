// Prisma schema: the single source of truth for the LiveStore + TanStack DB
// todo model. Three generators consume it:
//
//   1. `effect_client` — the published `prisma-effect-schema-generator`
//      npm package. Emits `@livestore/utils/effect` `Schema.*` values
//      plus the introspection maps the integration factory consumes
//      (`PRIMARY_KEY_COLUMNS`, `SOFT_DELETE_COLUMNS`, `TABLES`).
//
//   2. `livestore` — the in-repo `@cyberistic/livestore-prisma` package's
//      generator. Reads a sidecar `livestore.annotations.json` for
//      per-table flags (serverOnly, custom event names) and emits
//      LiveStore-specific code: tables, events, materializers,
//      makeSchema. The annotations file is the per-table flag surface
//      — no regex guessing.
//
//   3. `client` — the standard Prisma Client, useful for ad-hoc D1 reads.
//
// `provider = "sqlite"` is what Prisma uses for local type checking +
// migration generation. The actual D1 database is provisioned by
// Alchemy (`alchemy.run.ts`) and Prisma's migration SQL is diff'd into
// `prisma/migrations/` then pointed at via `Cloudflare.D1.Database`'s
// `migrationsDir`.
datasource db {
  provider = "sqlite"
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

generator effect_client {
  provider            = "prisma-effect-schema-generator"
  output              = "./generated/client-schemas/index.ts"
  // Introspection maps the integration factory consumes:
  idColumn            = "true"
  softDeleteColumn    = "true"
  tables              = "true"
  exportModelNames    = "true"
  exportModelNameType = "true"
  // Wrap every schema in `Schema.standardSchemaV1(...)` so it satisfies
  // Standard Schema v1 (TanStack DB accepts it directly via
  // `CollectionConfig.schema`). Fixed in 0.1.8 — the destructive
  // `as unknown as Schema.Schema<unknown, unknown, never>` cast that
  // erased the row type was removed upstream (issue #2).
  standardSchemaV1    = "true"
}

model Todo {
  id        String    @id
  text      String
  completed Boolean   @default(false)
  createdAt DateTime  @default(now())
  deletedAt DateTime? @map("deleted_at")

  @@map("todos")
}

// LiveStore's `events` log. This is the durable, queryable mirror that
// the LiveStore sync-cf Durable Object writes to on every `onPush`. It
// is *not* the source of truth — LiveStore's own SQLite event log is —
// but it lets you replay history into other systems, run analytics, or
// rebuild a region from a backup.
//
// serverOnly: see `prisma/livestore.annotations.json`. The
// `prisma-livestore-generator` reads that flag and emits the table
// without commit handlers, so consumers can't accidentally .insert
// or .update on it from a TanStack DB collection.
model Event {
  id        Int      @id @default(autoincrement())
  storeId   String   @map("store_id")
  name      String
  args      String
  createdAt DateTime @default(now()) @map("created_at")

  @@index([storeId, id])
  @@map("events")
}
